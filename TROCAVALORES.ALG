Algoritmo "trocaValores"

Var

   a,b,c: inteiro

Inicio

      a <- 15
      b <- 30
      
      escreval("O valor de A ť: ", a)
      escreval("O valor de B ť: ", b)
      
      c <- a
      a <- b
      b <- c
      
      escreval("O valor de A ť: ", a)
      escreval("O valor de B ť: ", b)
      
Fimalgoritmo